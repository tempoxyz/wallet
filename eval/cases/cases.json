{
  "version": 1,
  "description": "Skill eval for presto. Tests whether agents know when and how to use presto given its SKILL.md.",
  "cases": [
    {
      "id": "llm-ask-gpt",
      "category": "trigger-positive",
      "prompt": "Ask GPT-4o-mini what the best sorting algorithm for nearly-sorted data is. Just give me the answer.",
      "expect": {
        "presto": {
          "should_invoke": true,
          "url_pattern": "payments\\.tempo\\.xyz.*/v1/chat/completions",
          "method": "POST",
          "has_flag": "--json",
          "json_checks": [".messages | type == \"array\"", ".model | type == \"string\""]
        }
      }
    },
    {
      "id": "llm-ask-claude",
      "category": "trigger-positive",
      "prompt": "Use the Anthropic API to ask Claude what a monad is. Short answer only.",
      "expect": {
        "presto": {
          "should_invoke": true,
          "url_pattern": "payments\\.tempo\\.xyz.*/v1/(messages|chat/completions)",
          "method": "POST",
          "has_flag": "--json"
        }
      }
    },
    {
      "id": "llm-openrouter",
