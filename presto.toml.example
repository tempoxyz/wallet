# Example presto configuration file
#
# Locations:
#   macOS:   ~/Library/Application Support/presto/config.toml
#   Linux:   ~/.config/presto/config.toml
#
# Alternatively, run `presto login` to create this file interactively.

# =============================================================================
# EVM Wallet Configuration
# =============================================================================
# Also accepts [tempo] as an alias for [evm]
# Run `presto login` to connect your Tempo wallet.

[evm]

# =============================================================================
# RPC Overrides for Built-in Networks
# =============================================================================
# Typed overrides for Tempo networks (highest priority)

# tempo_rpc = "https://my-custom-tempo-rpc.com"
# moderato_rpc = "https://my-custom-moderato-rpc.com"

# General RPC overrides (for any network by id)
# [rpc]
# tempo = "https://alternate-tempo-rpc.com"
# "tempo-moderato" = "https://alternate-moderato-rpc.com"

# =============================================================================
# Custom Network Definitions
# =============================================================================
# Define additional EVM networks beyond the built-in Tempo networks.
# Custom networks are checked before built-in networks when resolving.

# [[networks]]
# id = "my-local-chain"
# chain_id = 31337
# mainnet = false
# display_name = "Local Dev Chain"
# rpc_url = "http://localhost:8545"
# explorer_url = "http://localhost:4000"

# [[networks]]
# id = "my-tempo-fork"
# chain_id = 99999
# mainnet = true
# display_name = "My Tempo Fork"
# rpc_url = "https://rpc.mytempofork.com"
